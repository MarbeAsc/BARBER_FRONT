# URL base para desarrollo local.
VITE_API_URL=http://localhost:5064/api

# URL base para builds de despliegue (dev/qa/test/production).
# VITE_API_URL_PRODUCTION=https://qa.smanfora.gruporfacil.com/api/

# Fallback local opcional.
# VITE_API_URL_LOCAL=http://127.0.0.1:7260/api

# Endpoint de login relativo a VITE_API_URL.
VITE_AUTH_LOGIN_PATH=/usuario/login

# Registrar service worker en desarrollo (por defecto solo en build).
# VITE_ENABLE_SW_DEV=true
